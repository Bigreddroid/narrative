{
  "_meta": {
    "description": "Curated native search-URL templates, keyed by host -> {entityKind: urlTemplate}. {value} is replaced with the URL-encoded entity. These ADD TO / OVERRIDE the in-code NATIVE_SEARCH seed in backend/services/osint_catalog.py (merged at load). Hosts not listed here (or in the seed) fall back to a site-scoped search. Curated for reliability; run scripts/check_osint_links.py to detect rot.",
    "license": "Search-URL patterns curated for The Narrative."
  },
