# Treat binary assets as binary so Git never applies EOL conversion (which would
# corrupt them on checkout under core.autocrlf on Windows).
*.pdf  binary
*.dump binary
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.woff binary
*.woff2 binary

# Normalize source line endings to LF in the repo (checked out per-platform).
*.py   text eol=lf
*.js   text eol=lf
*.jsx  text eol=lf
*.mjs  text eol=lf
*.ts   text eol=lf
*.sh   text eol=lf
*.command text eol=lf
*.yml  text eol=lf
*.yaml text eol=lf

# Windows launchers must keep CRLF so cmd.exe/PowerShell parse them correctly.
*.bat  text eol=crlf
*.cmd  text eol=crlf
*.ps1  text eol=crlf
