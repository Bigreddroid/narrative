# Plug-and-play defaults for `docker compose up`. NO secrets — safe to commit.
# The demo serves the bundled real data; AI keys are only needed for the
# (optional) live pipeline: `docker compose --profile pipeline up`.
APP_ENV=development
SECRET_KEY=dev-demo-secret-change-me
DATABASE_URL=postgresql+asyncpg://narrative:narrative@postgres:5432/narrative
REDIS_URL=redis://redis:6379/0
ANTHROPIC_API_KEY=
VOYAGE_API_KEY=
ALLOWED_ORIGINS=http://localhost:8080,http://localhost:5173,http://localhost:3000
