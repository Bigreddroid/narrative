{
  "expo": {
    "name": "The Narrative",
    "slug": "narrative",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0D1117"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "io.thenarrative.app",
      "infoPlist": {
        "NSUserNotificationUsageDescription": "Receive alerts when events you follow escalate."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0D1117"
      },
      "package": "io.thenarrative.app",
      "googleServicesFile": "./google-services.json",
      "permissions": ["RECEIVE_BOOT_COMPLETED", "VIBRATE"]
    },
    "notification": {
      "icon": "./assets/notification-icon.png",
      "color": "#F5A623",
      "androidMode": "default"
    },
    "plugins": [
      ["expo-notifications", {
        "icon": "./assets/notification-icon.png",
        "color": "#F5A623"
      }],
      ["expo-build-properties", {
        "android": {
          "compileSdkVersion": 34,
          "targetSdkVersion": 34,
          "buildToolsVersion": "34.0.0"
        }
      }]
    ],
    "extra": {
      "eas": {
        "projectId": "narrative-app"
      }
    }
  }
}
