[Unit]
Description=Narrative Pipeline Scheduler
After=network.target postgresql.service

[Service]
Type=simple
User=root
WorkingDirectory=/mnt/c/Users/Varun/OneDrive/Desktop/Narrative v5
Environment=PYTHONPATH=/mnt/c/Users/Varun/OneDrive/Desktop/Narrative v5
ExecStart=/opt/narrative-venv312/bin/python -m backend.scheduler
