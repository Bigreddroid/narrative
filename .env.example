# ─── AI providers ─────────────────────────────────────────────────────────────
# FREE BY DEFAULT. With the settings below the whole pipeline runs locally at $0
# (Ollama for the LLM, fastembed for embeddings). The API keys further down are
# OPTIONAL and only used when PAID_APIS_ENABLED=true.
PAID_APIS_ENABLED=false
LLM_PROVIDER=ollama            # ollama (local/free) | anthropic (paid) | off
EMBEDDINGS_PROVIDER=local      # local (free) | voyage (paid)

# Local (free) models — need a running Ollama: `ollama pull llama3.2`.
# qwen2.5:7b gives sharper mapping JSON if you'd rather pull that instead.
# fastembed downloads the embedding model automatically on first use.
OLLAMA_BASE_URL=http://localhost:11434
LOCAL_LLM_MODEL=llama3.2:latest
LOCAL_EMBEDDING_MODEL=BAAI/bge-large-en-v1.5

# Paid provider keys — ONLY consulted when PAID_APIS_ENABLED=true. Leave blank for
# a fully free/local run.
ANTHROPIC_API_KEY=
VOYAGE_API_KEY=

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/narrative
REDIS_URL=redis://localhost:6379/0

# ─── Auth ─────────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_KEY=eyJ...

# ─── Payments ─────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID=price_narrative_paid_699
REVENUECAT_API_KEY=...

# ─── Email (cost alerts) ──────────────────────────────────────────────────────
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASSWORD=SG....

# ─── Notifications ────────────────────────────────────────────────────────────
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# ─── Maritime / AIS (optional) ────────────────────────────────────────────────
# Server-side vessel source for the maritime overlay (GET /api/v1/vessels).
# AISHub membership username (https://www.aishub.net). Leave blank to disable —
# the frontend then falls back to AISStream (VITE_AISSTREAM_KEY) → simulated.
AISHUB_USERNAME=

# ─── Storage ──────────────────────────────────────────────────────────────────
CLOUDFLARE_R2_ACCESS_KEY=...
CLOUDFLARE_R2_SECRET_KEY=...
CLOUDFLARE_R2_BUCKET=narrative-archive
CLOUDFLARE_R2_ENDPOINT=https://account.r2.cloudflarestorage.com

# ─── OSINT (open-source intelligence) ─────────────────────────────────────────
# The OSINT worker pulls noisy open-source items and runs each through the local
# LLM triage agent before any becomes an event. Two selectable sources:
#   gdelt  (default) — keyless GDELT DOC news API. No account, works from any IP.
#   reddit           — hot posts from OSINT_SUBREDDITS. Reddit blocks the anon
#                      endpoint (HTTP 403) AND app creation on low-karma accounts,
#                      so this needs the app-only OAuth creds below to work at all.
OSINT_SOURCE=gdelt
OSINT_SUBREDDITS=worldnews,geopolitics,CredibleDefense
# Only needed when OSINT_SOURCE=reddit. Create an app at
# https://www.reddit.com/prefs/apps ("create app" → type "script") to get these.
REDDIT_USER_AGENT=the-narrative-osint/0.2 (by /u/your-reddit-username)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# ─── Live news (embedded player) ──────────────────────────────────────────────
# Default = curated OFFICIAL broadcaster HLS/YouTube channels only ($0, keyless).
# iptv-org is a huge keyless HLS catalog of UNOFFICIAL restreams (copyright/geo/
# uptime risk) — opt-in only, never the shipped default.
LIVE_NEWS_USE_IPTV_ORG=false
LIVE_NEWS_IPTV_ORG_URL=https://iptv-org.github.io/iptv/categories/news.m3u

# ─── Bias data ────────────────────────────────────────────────────────────────
ALLSIDES_API_KEY=...

# ─── Monitoring ───────────────────────────────────────────────────────────────
SENTRY_DSN=https://...@sentry.io/...
POSTHOG_API_KEY=phc_...

# ─── Pipeline config ──────────────────────────────────────────────────────────
CONSEQUENCE_ENGINE_MODEL=claude-sonnet-4-20250514
EMBEDDING_MODEL=voyage-large-2
IMPORTANCE_THRESHOLD_DEEP=70
IMPORTANCE_THRESHOLD_LIGHT=40
CLUSTER_SIMILARITY_THRESHOLD=0.82
GRAPH_CONNECTION_THRESHOLD=0.35
MAX_CHAIN_STEPS=6
SCRAPE_INTERVAL_HOURS=2
EMBED_INTERVAL_MINUTES=15
CLUSTER_INTERVAL_MINUTES=30
IMPORTANCE_INTERVAL_MINUTES=30
MAPPING_INTERVAL_MINUTES=15
GRAPH_INTERVAL_HOURS=1
EVOLUTION_INTERVAL_HOURS=1
ALERT_INTERVAL_MINUTES=30
FEED_REBUILD_INTERVAL_HOURS=1
OUTCOME_EVAL_INTERVAL_DAYS=7
ARCHIVE_INTERVAL_HOURS=24

# ─── Cost control ─────────────────────────────────────────────────────────────
# Soft alerts (email only — do not stop spending):
CLAUDE_DAILY_COST_ALERT_USD=20
CLAUDE_MONTHLY_BUDGET_USD=200
ADMIN_ALERT_EMAIL=admin@example.com
# ENFORCED hard caps: paid LLM calls are blocked once spend reaches these and the
# pipeline degrades to the free/local path. 0 = no paid spend permitted at all
# (raise these only when PAID_APIS_ENABLED=true and you want to allow spend).
CLAUDE_HARD_CAP_DAILY_USD=0
CLAUDE_HARD_CAP_MONTHLY_USD=0

# ─── Data lifecycle ───────────────────────────────────────────────────────────
HOT_DATA_DAYS=30
WARM_DATA_MONTHS=6

# ─── App ──────────────────────────────────────────────────────────────────────
APP_ENV=development
SECRET_KEY=change-this-to-a-random-secret-key-in-production
# Comma-separated browser origins allowed by CORS. In prod set to your Vercel URL,
# e.g. https://app.thenarrative.io  (only needed if the frontend calls the API
# cross-origin; with the Vercel /api rewrite the request is same-origin).
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
# Base URL of the deployed frontend — used to build Stripe success/cancel/return
# URLs. Locally set to http://localhost:5173 to test checkout redirects.
APP_BASE_URL=https://app.thenarrative.io
