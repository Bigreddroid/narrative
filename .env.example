# ─── AI ───────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
VOYAGE_API_KEY=pa-...

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/narrative
REDIS_URL=redis://localhost:6379/0

# ─── Auth ─────────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_KEY=eyJ...

# ─── Payments ─────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID=price_narrative_paid_699
REVENUECAT_API_KEY=...

# ─── Email (cost alerts) ──────────────────────────────────────────────────────
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASSWORD=SG....

# ─── Notifications ────────────────────────────────────────────────────────────
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# ─── Maps ─────────────────────────────────────────────────────────────────────
MAPBOX_PUBLIC_TOKEN=pk.eyJ1...

# ─── Storage ──────────────────────────────────────────────────────────────────
CLOUDFLARE_R2_ACCESS_KEY=...
CLOUDFLARE_R2_SECRET_KEY=...
CLOUDFLARE_R2_BUCKET=narrative-archive
CLOUDFLARE_R2_ENDPOINT=https://account.r2.cloudflarestorage.com

# ─── Bias data ────────────────────────────────────────────────────────────────
ALLSIDES_API_KEY=...

# ─── Monitoring ───────────────────────────────────────────────────────────────
SENTRY_DSN=https://...@sentry.io/...
POSTHOG_API_KEY=phc_...

# ─── Pipeline config ──────────────────────────────────────────────────────────
CONSEQUENCE_ENGINE_MODEL=claude-sonnet-4-20250514
EMBEDDING_MODEL=voyage-large-2
IMPORTANCE_THRESHOLD_DEEP=70
IMPORTANCE_THRESHOLD_LIGHT=40
CLUSTER_SIMILARITY_THRESHOLD=0.82
GRAPH_CONNECTION_THRESHOLD=0.35
MAX_CHAIN_STEPS=6
SCRAPE_INTERVAL_HOURS=2
EMBED_INTERVAL_MINUTES=15
CLUSTER_INTERVAL_MINUTES=30
IMPORTANCE_INTERVAL_MINUTES=30
MAPPING_INTERVAL_MINUTES=15
GRAPH_INTERVAL_HOURS=1
EVOLUTION_INTERVAL_HOURS=1
ALERT_INTERVAL_MINUTES=30
FEED_REBUILD_INTERVAL_HOURS=1
OUTCOME_EVAL_INTERVAL_DAYS=7
ARCHIVE_INTERVAL_HOURS=24

# ─── Cost control ─────────────────────────────────────────────────────────────
CLAUDE_DAILY_COST_ALERT_USD=20
CLAUDE_MONTHLY_BUDGET_USD=200
ADMIN_ALERT_EMAIL=admin@example.com

# ─── Data lifecycle ───────────────────────────────────────────────────────────
HOT_DATA_DAYS=30
WARM_DATA_MONTHS=6

# ─── App ──────────────────────────────────────────────────────────────────────
APP_ENV=development
SECRET_KEY=change-this-to-a-random-secret-key-in-production
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
