# ════════════════════════════════════════════════════════════════════════════
#  PRODUCTION env template for Railway (backend: api + scheduler services).
#  Copy each var into the Railway service "Variables" tab. DO NOT commit real
#  values — this file documents names only. Frontend (Vite) vars go in Vercel,
#  not here (see bottom).
# ════════════════════════════════════════════════════════════════════════════

# ─── REQUIRED ─────────────────────────────────────────────────────────────────

# AI pipeline (rotate the keys that were exposed in the old .env before using!)
ANTHROPIC_API_KEY=sk-ant-...
VOYAGE_API_KEY=pa-...

# Database + Redis: DO NOT hardcode. Reference the Railway plugin variables.
# IMPORTANT: the app feeds DATABASE_URL straight into create_async_engine (see
# backend/config.py + backend/database.py) and does NOT rewrite the scheme — so
# the value MUST use the +asyncpg driver, or the app crashes on boot. Railway's
# Postgres plugin only exposes a plain postgresql:// URL, so COMPOSE it from the
# plugin's parts (private networking, stays in sync if PG is recreated):
#   DATABASE_URL = postgresql+asyncpg://${{Postgres.PGUSER}}:${{Postgres.PGPASSWORD}}@${{Postgres.RAILWAY_PRIVATE_DOMAIN}}:5432/${{Postgres.PGDATABASE}}
#   REDIS_URL    = ${{ Redis.REDIS_URL }}
# (Alembic in env.py self-converts either scheme, so migrations pass regardless —
# only the app is strict. Use a pgvector-capable Postgres: migrations + the data
# dump run CREATE EXTENSION vector.)
DATABASE_URL=postgresql+asyncpg://...railway-postgres...
REDIS_URL=redis://...railway-redis...

# Runtime mode — MUST be "production": disables /docs & /redoc, INFO logging,
# gunicorn (no reload).
APP_ENV=production

# JWT signing key — generate a long random value (e.g. `openssl rand -hex 32`).
# Changing it invalidates all existing sessions.
SECRET_KEY=GENERATE-A-RANDOM-64-CHAR-HEX-SECRET

# CORS allowlist — your Vercel domain(s), comma-separated. Keep explicit (never
# "*"). With the Vercel /api rewrite the browser call is same-origin, but set
# this anyway for safety / direct API use.
ALLOWED_ORIGINS=https://your-app.vercel.app

# Base URL of the deployed frontend — used to build Stripe success/cancel URLs.
APP_BASE_URL=https://your-app.vercel.app

# ─── OPTIONAL (features degrade gracefully if blank) ──────────────────────────

# Supabase auth exchange (email/password auth works without it)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=

# Stripe billing (paid tiers). Without these, checkout/portal/webhook are inert.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=

# Push notifications (FCM). Without it, alert_worker can't deliver pushes.
FIREBASE_SERVICE_ACCOUNT_JSON=

# Cost-alert emails (SMTP). Without it, budget alerts are not emailed.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
ADMIN_ALERT_EMAIL=

# Maritime overlay server source (else frontend AISStream / none)
AISHUB_USERNAME=

# Cold-storage archive of old articles (archive_worker). Free tier is plenty.
CLOUDFLARE_R2_ACCESS_KEY=
CLOUDFLARE_R2_SECRET_KEY=
CLOUDFLARE_R2_BUCKET=
CLOUDFLARE_R2_ENDPOINT=

# Bias ratings refresh
ALLSIDES_API_KEY=

# Monitoring (recommended for prod — enable Sentry at least)
SENTRY_DSN=
POSTHOG_API_KEY=

# ─── TUNABLES (have sane defaults in backend/config.py; override only if needed)
CONSEQUENCE_ENGINE_MODEL=claude-sonnet-4-20250514
EMBEDDING_MODEL=voyage-large-2
CLAUDE_DAILY_COST_ALERT_USD=20
CLAUDE_MONTHLY_BUDGET_USD=200
# (scrape/embed/cluster/mapping intervals, thresholds, data-lifecycle — see .env.example)

# ════════════════════════════════════════════════════════════════════════════
#  FRONTEND — set these in VERCEL (Project → Settings → Environment Variables),
#  NOT in Railway:
#    VITE_MAPBOX_TOKEN   = pk.eyJ...           (Mapbox public token; free tier)
#    VITE_AISSTREAM_KEY  = (optional, live AIS in browser)
#  DO NOT set VITE_DEMO_MODE — leaving it unset keeps the app on REAL data only.
# ════════════════════════════════════════════════════════════════════════════
