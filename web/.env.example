# Frontend env (Vite). Copy to web/.env for local, or set in Vercel for prod.
# NOTE: the app calls the API at the relative path /api/v1, so no API URL is
# needed here — locally the Vite dev proxy and in prod the Vercel /api rewrite
# (see vercel.json) forward those to the backend.

# Mapbox public token (world map). Required.
VITE_MAPBOX_TOKEN=pk.eyJ1...

# Show built-in mock/sample data when the backend is unreachable. Leave FALSE for
# real beta builds (the app then shows real data or an honest empty/error state).
VITE_DEMO_MODE=false

# Optional — live ship tracking via AISStream (https://aisstream.io, free key).
# If unset, the Maritime layer shows a clearly-badged simulated fleet.
VITE_AISSTREAM_KEY=
